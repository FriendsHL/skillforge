# Comma-separated endpoints added to Mobile Devices pairing QR payloads.
# Use addresses that the iPhone can reach. Keep the LAN address first.
VITE_SKILLFORGE_MOBILE_ENDPOINTS=http://192.168.1.6:3000,https://your-mac.your-tailnet.ts.net

# Required when Vite is exposed through Tailscale Serve in development.
__VITE_ADDITIONAL_SERVER_ALLOWED_HOSTS=your-mac.your-tailnet.ts.net
